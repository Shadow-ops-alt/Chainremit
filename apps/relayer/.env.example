# ── Server ───────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── Frontend origin (no trailing slash) ──────────────────
WEB_BASE_URL=http://localhost:5173

# ── Solana ───────────────────────────────────────────────
# RPC endpoint — use Helius or QuickNode for production
SOLANA_RPC_URL=https://api.devnet.solana.com

# Relayer keypair as a JSON array of 64 bytes
# Generate: node -e "const {Keypair}=require('@solana/web3.js'); console.log(JSON.stringify(Array.from(Keypair.generate().secretKey)))"
RELAYER_PRIVATE_KEY=

# ── Agent PIN auth ────────────────────────────────────────
# Optional: set a salt + hashed PIN instead of plain AGENT_PIN
# Hash: node -e "const c=require('crypto'); const salt='YOURSALT'; const pin='YOURPIN'; console.log(c.createHash('sha256').update(salt+pin).digest('hex'))"
AGENT_PIN_SALT=
AGENT_PIN_HASH=
# Fallback plain PIN (only used if AGENT_PIN_HASH is not set — dev only)
AGENT_PIN=1234

# ── Metaplex cNFT receipt minting ────────────────────────
# Leave blank to skip NFT minting (demo still works without these)
MERKLE_TREE_ADDRESS=
COLLECTION_MINT=
# Optional metadata URI override for receipt NFT metadata JSON
NFT_METADATA_URI=
